export component WelcomePageStats {
    in-out property <int> memory_usage: 0;
    in-out property <int> cpu_usage: 0;
    in-out property <int> disk_usage: 0;
    in-out property <bool> is_connected: false;

    Rectangle {
        background: #1E293B;
        border-radius: 12px;
        border-width: 1px;
        border-color: #334155;
        width: 100%;
        
        drop-shadow-color: #00000040;
        drop-shadow-blur: 8px;
        drop-shadow-offset-y: 4px;

        HorizontalLayout {
            padding: 24px;
            alignment: space-between;

            VerticalLayout {
                spacing: 16px;

                Text {
                    text: "Estatísticas do Sistema";
                    font-size: 18px;
                    font-weight: 700;
                    color: #F8FAFC;
                }

                HorizontalLayout {
                    spacing: 32px;

                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "CPU"; font-size: 12px; color: #94A3B8; font-weight: 600; }
                        Text { text: root.cpu_usage + "%"; font-size: 20px; color: #38BDF8; font-weight: 700; }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "RAM"; font-size: 12px; color: #94A3B8; font-weight: 600; }
                        Text { text: root.memory_usage + "%"; font-size: 20px; color: #34D399; font-weight: 700; }
                    }

                    VerticalLayout {
                        spacing: 4px;
                        Text { text: "Disco"; font-size: 12px; color: #94A3B8; font-weight: 600; }
                        Text { text: root.disk_usage + "%"; font-size: 20px; color: #A78BFA; font-weight: 700; }
                    }
                }
            }

            VerticalLayout {
                spacing: 10px;
                padding-bottom: 28px;
                
                Text { text: "Status da conexão"; font-size: 18px; font-weight: 700; color: #F8FAFC; }

                Text { text: root.is_connected ? "Conectado" : "Desconectado"; font-size: 18px; color: #34D399; font-weight: 600; }
            }
        }
    }
}